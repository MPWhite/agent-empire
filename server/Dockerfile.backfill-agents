FROM node:20-slim AS builder
WORKDIR /app
COPY package.json package-lock.json ./
COPY engine/package.json engine/
COPY server/package.json server/
RUN npm ci --workspace=engine --workspace=server
COPY tsconfig.base.json ./
COPY engine/ engine/
COPY server/ server/
RUN npm run build -w engine && npm run build -w server

FROM node:20-slim
WORKDIR /app
COPY --from=builder /app/package.json /app/package-lock.json ./
COPY --from=builder /app/engine/package.json engine/
COPY --from=builder /app/server/package.json server/
RUN npm ci --workspace=engine --workspace=server --omit=dev
COPY --from=builder /app/engine/dist engine/dist
COPY --from=builder /app/server/dist server/dist
ENV NODE_ENV=production
CMD ["node", "server/dist/backfill-agents.js"]
